[Unit]
Description=Turnstile Agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/turnstile-agent
EnvironmentFile=/opt/turnstile-agent/.env
Environment=TZ=Europe/Oslo
ExecStart=/opt/turnstile-agent/turnstile-agent
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
